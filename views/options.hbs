<header>
    <div class='w3-bar w3-center black-yellow'>
        <a class='w3-bar-item w3-btn w3-mobile' href='/random'>{{t "menu.pwdGenerator"}}</a>
        <div class='w3-right' style='display: table;'>
            <div class='w3-padding w3-mobile' style='float: left; position:relative;'>{{t "menu.currentUser"}}{{user}}</div>
            <a href='/options' class='w3-btn w3-mobile' style='height: 45px; float: left; position:relative;'>{{t "menu.options"}} <i class='fas fa-user-edit'></i></a>
            <a class='w3-bar-item w3-button w3-border w3-border-black w3-mobile' href='/index'>{{t "menu.backHome"}} <i class='fas fa-home'></i></a>
            <a class='w3-bar-item w3-button w3-red w3-text-black w3-hover-black w3-hover-text-red w3-border w3-border-red w3-mobile' href='/login'>{{t "menu.logout"}} <i class='fas fa-sign-out-alt'></i></a>
        </div>
    </div>
    <h1 class='w3-center w3-xxlarge yellow-black'><b>{{t "options.panelTitle"}}</b></h1>
</header>
<br>
{{#if azione}}
    {{#if azione.cambia}}
        {{#if error}}
            <div id='errore' class='w3-modal-content w3-red w3-text-black w3-center w3-animate-zoom other' style='width:300px;'>
                <span onclick="document.getElementById('errore').style.display='none'" class='w3-button w3-display-topright'>&times;</span>
                <h3><i class='fas fa-exclamation-triangle'></i> {{t "error"}}</h3>
                <span>{{t "options.errWrongOldPwd"}}</span>
            </div>
        {{else if same}}
            <div id='same' class='w3-modal-content w3-red w3-text-black w3-center w3-animate-zoom other' style='width:300px;'>
                <span onclick="document.getElementById('same').style.display='none'" class='w3-button w3-display-topright'>&times;</span>
                <h3><i class='fas fa-exclamation-triangle'></i> {{t "error"}}</h3>
                <span>{{t "options.errNewPwdSameAsOld"}}</span>
            </div>
        {{else if post}}
            <div class='w3-panel w3-green w3-text-black w3-center other' style='width:400px; margin: auto;'>
                <p>
                    {{t "options.msgPwdSuccess"}}<br>
                    <a class='w3-btn w3-white w3-text-green' href='/index'>{{t "menu.backHome"}} <i class='fas fa-undo-alt'></i></a>
                </p>
            </div>
        {{/if}}
        <br>
        <div id='diverse' class='w3-modal'>
            <div class='w3-modal-content w3-animate-zoom'>
                <div class='w3-container w3-red w3-text-black w3-center w3-xlarge'>
                    <span onclick="document.getElementById('diverse').style.display='none'" class='w3-button w3-display-topright'>&times;</span>
                    <i class='fas fa-exclamation-triangle'></i> {{t "error"}}
                    <p>{{t "options.errPwdMatch"}}</p>
                </div>
            </div>
        </div>
        <div class='w3-container' style='width: 350px; margin: auto;'>
            <fieldset class='w3-card w3-border-black'>
                <legend class='w3-large w3-center'><b>{{t "options.titleEditPwd"}}</b></legend>
                <form action='/options/editPwd' method='post' class='w3-container black-yellow' onsubmit='return checkPwd();'>
                    <input type='hidden' name='_csrf' value='{{csfrToken}}'>
                    <div class='w3-panel'>
                        <label><i class='fas fa-key'></i> {{t "options.oldPwd"}}</label>
                        <input type='password' name='oldpwd' class='w3-input w3-border yellow-black' pattern='.{8,255}' required autofocus />
                    </div>
                    <div class='w3-panel'>
                        <label><i class='fas fa-check'></i> {{t "options.newPwd"}}</label>
                        <input type='password' name='newpwd' id='pwd1' class='w3-input w3-border yellow-black' pattern='.{8,255}' required />
                    </div>
                    <div class='w3-panel'>
                        <label><i class='fas fa-check-double'></i> {{t "options.repeatPwd"}}</label>
                        <input type='password' name='pwd' id='pwd2' class='w3-input w3-border yellow-black' pattern='.{8,255}' required />
                    </div>
                    <div class='w3-panel w3-cell-row'>
                        <a href='/options' class='w3-btn w3-cell w3-left yellow-black' style='width: 49%;'>{{t "options.goBack"}}</a>
                        <input type='submit' class='w3-btn w3-cell w3-right yellow-black' style='width: 49%;' name='Cambia' id='btn' value='CONFERMA'>
                    </div>
                </form>
            </fieldset>
        </div>
    {{else if azione.elimina}}
        {{#if error}}
            <div id='errore' class='w3-modal-content w3-red w3-text-black w3-center w3-animate-zoom other' style='width:300px;'>
                <span onclick="document.getElementById('errore').style.display='none'" class='w3-button w3-display-topright'>&times;</span>
                <h3><i class='fas fa-exclamation-triangle'></i> {{t "error"}}</h3>
                <span>{{t "options.errWrongPwd"}}</span>
            </div>
        {{/if}}
        <br>
        <div class='w3-container w3-center' style='width: 500px; margin: auto;'>
            <h2 class='w3-text-red w3-jumbo' style='font-family: ' Blender Pro';'>{{t "options.warning"}}</h2>
            <form action='/options/deleteAccount' method='post' class='w3-container black-yellow'>
                <input type='hidden' name='_csrf' value='{{csfrToken}}'>
                <div class='w3-left-align'>{{t "options.deletAccountMsg"}}</div>
                <div class='w3-panel'>
                    <label><i class='fas fa-shield-alt'></i> {{t "options.confirmDeleteAccount"}}</label>
                    <input type='password' name='oldpwd' class='w3-input w3-border yellow-black' pattern='.{8,255}' required />
                </div>
                <div class='w3-panel w3-cell-row'>
                    <a href='/options' class='w3-btn w3-cell w3-left yellow-black' style='width: 49%;'>{{t "options.goBack"}}</a>
                    <input type='submit' class='w3-btn w3-cell w3-right yellow-black' style='width: 49%;' name='Elimina' id='btn' value='CONFERMA' onclick="return confirm('Conferma l\'eliminazione dell'account')">
                </div>
            </form>
        </div>
    {{else if azione.sicurezza}}
        {{#if post.salva}}
            {{#if error}}
                <div id='errore' class='w3-modal-content w3-red w3-text-black w3-center w3-animate-zoom other' style='width:450px;'>
                    <span onclick="document.getElementById('errore').style.display='none'" class='w3-button w3-display-topright'>&times;</span>
                    <h3><i class='fas fa-exclamation-triangle'></i> {{t "error"}}</h3>
                    <span>{{t "options.errWrongPwd"}}</span>
                </div>
            {{else}}
                {{#if post.sicurezza}}
                    <div class='w3-panel w3-green w3-text-black w3-center other' style='width:400px; margin: auto;'>
                        <p>
                            {{t "options.pinSetMsg"}}<br>
                            <a class='w3-btn w3-white w3-text-green' href='/index'>{{t "menu.backHome"}} <i class='fas fa-undo-alt'></i></a>
                        </p>
                    </div>
                {{else}}
                    <div class='w3-panel w3-green w3-text-black w3-center other' style='width:400px; margin: auto;'>
                        <p>
                            {{t "options.pinDeletedMsg"}}<br>
                            <a class='w3-btn w3-white w3-text-green' href='/index'>{{t "menu.backHome"}} <i class='fas fa-undo-alt'></i></a>
                        </p>
                    </div>
                {{/if}}
            {{/if}}
        {{/if}}
        <br>
        {{#if pin}}
            <script>
                function verifica(radio) {
                    if (radio.value == 'pin') {
                        document.getElementById('btn').disabled = true;
                        document.getElementById('conferma').style.display = 'none';
                    }
                    else {
                        document.getElementById('btn').disabled = false;
                        document.getElementById('conferma').style.display = 'block';
                    }
                }
            </script>
        {{else}}
            <script>
                function verifica(radio) {
                    if (radio.value == 'nessuna')
                        document.getElementById('ins_pin').style.display = 'none';
                    else
                        document.getElementById('ins_pin').style.display = 'block';
                }

                function conferma() {
                    var p1 = document.getElementById('pwd1').value;
                    var p2 = document.getElementById('pwd2').value;
                    var pattern1 = /\d{4,8}/g;
                    var pattern2 = /\d{4,8}/g;

                    if (pattern1.test(p1) && pattern2.test(p2))
                        document.getElementById('conferma').style.display = 'block';
                    else
                        document.getElementById('conferma').style.display = 'none';
                }

                function salva() {
                    if (document.getElementById('conferma').value != '')
                        document.getElementById('btn').disabled = false;
                    else
                        document.getElementById('btn').disabled = true;
                }

                function checkPwd() {
                    p1 = document.getElementById('pwd1').value;
                    p2 = document.getElementById('pwd2').value;
                    if (p1 == p2)
                        return true;
                    else {
                        document.getElementById('diverse').style.display = 'block';
                        return false;
                    }
                }
            </script>
        {{/if}}

        <div id='diverse' class='w3-modal'>
            <div class='w3-modal-content w3-animate-zoom'>
                <div class='w3-container w3-red w3-text-black w3-center w3-xlarge'>
                    <span onclick="document.getElementById('diverse').style.display='none'" class='w3-button w3-display-topright'>&times;</span>
                    <i class='fas fa-exclamation-triangle'></i> {{t "error"}}
                    <p>{{t "options.errPinMatch"}}</p>
                </div>
            </div>
        </div>

        <div class='w3-content' style='width: 600px; margin: auto;'>
            <fieldset class='w3-card w3-border-black'>
                <legend class='w3-large w3-center'><b>{{t "options.titlePinManagement"}}</b></legend>
                <form action='/options/securityManagement' method='post' onsubmit='return checkPwd();' class='w3-container black-yellow'>
                    <input type='hidden' name='_csrf' value='{{csfrToken}}'>
                    <div class='w3-panel'>
                        <input type='radio' name='sicurezza' value='nessuna' onclick='verifica(this);' {{#unless pin}}checked{{/unless}} class='w3-radio'>
                        <label>{{t "options.noPin"}}</label>
                        <div style='margin-left: 50px;'>{{t "options.noPinMsg"}}</div>
                    </div>
                    <div class='w3-panel'>
                        <input type='radio' name='sicurezza' value='pin' onclick='verifica(this);' {{#if pin}}checked{{/if}} class='w3-radio'>
                        <label>{{t "options.usePin"}}</label>
                        <div style='margin-left: 50px;'>{{t "options.usePinMsg"}}</div>
                        {{#unless pin}}
                            <div class='w3-container' id='ins_pin' style='display:none;'>
                                <div class='w3-panel'>
                                    <label>{{t "options.insertNewPin"}}</label>
                                    <input type='password' name='pin' id='pwd1' class='w3-input' oninput='conferma();'>
                                </div>
                                <div class='w3-panel'>
                                    <label>{{t "options.confirmNewPin"}}</label>
                                    <input type='password' id='pwd2' class='w3-input' oninput='conferma();'>
                                </div>
                            </div>
                        {{/unless}}
                    </div>
                    <div class='w3-panel w3-center' style='display:none;' id='conferma'>
                        <label><i class='fas fa-shield-alt'></i> {{t "options.confirmWithPwd"}}</label>
                        <input type='password' name='oldpwd' class='w3-input w3-border yellow-black' oninput='salva();' pattern='.{8,255}' required>
                    </div>
                    <div class='w3-panel w3-cell-row'>
                        <a href='/options' class='w3-btn w3-cell w3-left yellow-black' style='width: 49%;'>{{t "options.goBack"}}</a>
                        <input type='submit' class='w3-btn w3-cell w3-right yellow-black' style='width: 49%;' name='Salva' id='btn' value='SALVA' disabled>
                    </div>
                </form>
            </fieldset>
        </div>

    {{else if azione.pin}}
        {{#if error}}
            <div id='errore' class='w3-modal-content w3-red w3-text-black w3-center w3-animate-zoom other' style='width:300px;'>
                <span onclick="document.getElementById('errore').style.display='none'" class='w3-button w3-display-topright'>&times;</span>
                <h3><i class='fas fa-exclamation-triangle'></i> {{t "error"}}</h3>
                <span>{{t "options.errWrongOldPin"}}</span>
            </div>
        {{else if same}}
            <div id='same' class='w3-modal-content w3-red w3-text-black w3-center w3-animate-zoom other' style='width:300px;'>
                <span onclick="document.getElementById('same').style.display='none'" class='w3-button w3-display-topright'>&times;</span>
                <h3><i class='fas fa-exclamation-triangle'></i> {{t "error"}}</h3>
                <span>{{t "options.errNewPinSameAsOld"}}</span>
            </div>
        {{else if post}}
            <div class='w3-panel w3-green w3-text-black w3-center other' style='width:400px; margin: auto;'>
                <p>
                    {{t "options.msgPinSuccess"}}<br>
                    <a class='w3-btn w3-white w3-text-green' href='/index'>{{t "menu.backHome"}} <i class='fas fa-undo-alt'></i></a>
                </p>
            </div>
        {{/if}}
        <br>
        <div id='diverse' class='w3-modal'>
            <div class='w3-modal-content w3-animate-zoom'>
                <div class='w3-container w3-red w3-text-black w3-center w3-xlarge'>
                    <span onclick="document.getElementById('diverse').style.display='none'" class='w3-button w3-display-topright'>&times;</span>
                    <i class='fas fa-exclamation-triangle'></i> {{t "error"}}
                    <p>{{t "options.errPinMatch"}}</p>
                </div>
            </div>
        </div>
        <div class='w3-container' style='width: 350px; margin: auto;'>
            <fieldset class='w3-card w3-border-black'>
                <legend class='w3-large w3-center'><b>{{t "options.titleEditPin"}}</b></legend>
                <form action='/options/editPin' method='post' class='w3-container black-yellow' onsubmit='return checkPwd();'>
                    <input type='hidden' name='_csrf' value='{{csfrToken}}'>
                    <div class='w3-panel'>
                        <label><i class='fas fa-key'></i> {{t "options.oldPin"}}</label>
                        <input type='password' name='oldpin' class='w3-input w3-border yellow-black' pattern='[0-9]{4,8}' required />
                    </div>
                    <div class='w3-panel'>
                        <label><i class='fas fa-check'></i> {{t "options.newPin"}}</label>
                        <input type='password' name='newpin' id='pwd1' class='w3-input w3-border yellow-black' pattern='[0-9]{4,8}' required />
                    </div>
                    <div class='w3-panel'>
                        <label><i class='fas fa-check-double'></i> {{t "options.repeatNewPin"}}</label>
                        <input type='password' name='pin' id='pwd2' class='w3-input w3-border yellow-black' pattern='[0-9]{4,8}' required />
                    </div>
                    <div class='w3-panel w3-cell-row'>
                        <a href='/options' class='w3-btn w3-cell w3-left yellow-black' style='width: 49%;'>{{t "options.goBack"}}</a>
                        <input type='submit' class='w3-btn w3-cell w3-right yellow-black' style='width: 49%;' name='Pin' id='btn' value='CONFERMA'>
                    </div>
                </form>
            </fieldset>
        </div>
    {{else if azione.reset}}
        {{#if error}}
            <div id='errore' class='w3-modal-content w3-red w3-text-black w3-center w3-animate-zoom other' style='width:300px;'>
                <span onclick="document.getElementById('errore').style.display='none'" class='w3-button w3-display-topright'>&times;</span>
                <h3><i class='fas fa-exclamation-triangle'></i> {{t "error"}}</h3>
                <span>{{t "options.errWrongPwd"}}</span>
            </div>
        {{else if same}}
            <div id='same' class='w3-modal-content w3-red w3-text-black w3-center w3-animate-zoom other' style='width:300px;'>
                <span onclick="document.getElementById('same').style.display='none'" class='w3-button w3-display-topright'>&times;</span>
                <h3><i class='fas fa-exclamation-triangle'></i> {{t "error"}}</h3>
                <span>{{t "options.errNewPinSameAsOld"}}</span>
            </div>
        {{else if post}}
            <div class='w3-panel w3-green w3-text-black w3-center other' style='width:400px; margin: auto;'>
                <p>
                    {{t "options.msgPinSuccess"}}<br>
                    <a class='w3-btn w3-white w3-text-green' href='/index'>{{t "menu.backHome"}} <i class='fas fa-undo-alt'></i></a>
                </p>
            </div>
        {{/if}}
        <div id='diverse' class='w3-modal'>
            <div class='w3-modal-content w3-animate-zoom'>
                <div class='w3-container w3-red w3-text-black w3-center w3-xlarge'>
                    <span onclick="document.getElementById('diverse').style.display='none'" class='w3-button w3-display-topright'>&times;</span>
                    <i class='fas fa-exclamation-triangle'></i> {{t "error"}}
                    <p>{{t "options.errPinMatch"}}</p>
                </div>
            </div>
        </div>
        <div class='w3-container' style='width: 350px; margin: auto;'>
            <fieldset class='w3-card w3-border-black'>
                <legend class='w3-large w3-center'><b>{{t "options.titleResetPin"}}</b></legend>
                <form action='/options/resetPin' method='post' class='w3-container black-yellow' onsubmit='return checkPwd();'>
                    <input type='hidden' name='_csrf' value='{{csfrToken}}'>
                    <div class='w3-panel'>
                        <label><i class='fas fa-check'></i> {{t "options.newPin"}}</label>
                        <input type='password' name='newpin' id='pwd2' class='w3-input w3-border yellow-black' pattern='[0-9]{4,8}' required />
                    </div>
                    <div class='w3-panel'>
                        <label><i class='fas fa-check-double'></i> {{t "options.repeatNewPin"}}</label>
                        <input type='password' id='pwd1' class='w3-input w3-border yellow-black' pattern='[0-9]{4,8}' required />
                    </div>
                    <div class='w3-panel'>
                        <label><i class='fas fa-key'></i> {{t "options.confirmWithPwd"}}</label>
                        <input type='password' name='pwd' class='w3-input w3-border yellow-black' pattern='.{8,255}' required />
                    </div>
                    <div class='w3-panel w3-cell-row'>
                        <a href='/options' class='w3-btn w3-cell w3-left yellow-black' style='width: 49%;'>{{t "options.goBack"}}</a>
                        <input type='submit' class='w3-btn w3-cell w3-right yellow-black' style='width: 49%;' name='Reset' id='btn' value='CONFERMA'>
                    </div>
                </form>
            </fieldset>
        </div>
    {{else if azione.email}}
        {{#if error}}
            <div id='errore' class='w3-modal-content w3-red w3-text-black w3-center w3-animate-zoom other' style='width:300px;'>
                <span onclick="document.getElementById('errore').style.display='none'" class='w3-button w3-display-topright'>&times;</span>
                <h3><i class='fas fa-exclamation-triangle'></i> {{t "error"}}</h3>
                <span>{{t "options.errWrongPwd"}}</span>
            </div>
        {{else if same}}
            <div id='errore' class='w3-modal-content w3-red w3-text-black w3-center w3-animate-zoom other' style='width:300px;'>
                <span onclick="document.getElementById('errore').style.display='none'" class='w3-button w3-display-topright'>&times;</span>
                <h3><i class='fas fa-exclamation-triangle'></i> {{t "error"}}</h3>
                <span>{{t "options.emailAlreadyUsed"}}</span>
            </div>
        {{else if post}}
            <div class='w3-panel w3-green w3-text-black w3-center other' style='width:400px; margin: auto;'>
                <p>
                    {{t "options.msgEmailSuccess"}}<br>
                    <a class='w3-btn w3-white w3-text-green' href='/index'>{{t "menu.backHome"}} <i class='fas fa-undo-alt'></i></a>
                </p>
            </div>
        {{/if}}
        <br>
        <div id='diverse' class='w3-modal'>
            <div class='w3-modal-content w3-animate-zoom'>
                <div class='w3-container w3-red w3-text-black w3-center w3-xlarge'>
                    <span onclick="document.getElementById('diverse').style.display='none'" class='w3-button w3-display-topright'>&times;</span>
                    <i class='fas fa-exclamation-triangle'></i> {{t "error"}}
                    <p>{{t "options.errEmailMatch"}}</p>
                </div>
            </div>
        </div>
        <div class='w3-container' style='width: 350px; margin: auto;'>
            <fieldset class='w3-card w3-border-black'>
                <legend class='w3-large w3-center'><b>{{t "options.titleEditEmail"}}</b></legend>
                <form action='/options/editEmail' method='post' class='w3-container black-yellow' onsubmit='return checkPwd();'>
                    <input type='hidden' name='_csrf' value='{{csfrToken}}'>
                    <div class='w3-panel'>
                        <label><i class='fas fa-at'></i> {{t "options.currentEmail"}}</label>
                        <input type='email' name='oldmail' class='w3-input w3-border yellow-black' value='{{email}}' readonly />
                    </div>
                    <div class='w3-panel'>
                        <label><i class='fas fa-check'></i> {{t "options.newEmail"}}</label>
                        <input type='email' name='newmail' id='pwd1' class='w3-input w3-border yellow-black' required />
                    </div>
                    <div class='w3-panel'>
                        <label><i class='fas fa-check-double'></i> {{t "options.repeatNewEmail"}}</label>
                        <input type='email' id='pwd2' class='w3-input w3-border yellow-black' required />
                    </div>
                    <div class='w3-panel'>
                        <label><i class='fas fa-key'></i> {{t "options.confirmWithPwd"}}</label>
                        <input type='password' name='pwd' class='w3-input w3-border yellow-black' pattern='.{8,255}' required />
                    </div>
                    <div class='w3-panel w3-cell-row'>
                        <a href='/options' class='w3-btn w3-cell w3-left yellow-black' style='width: 49%;'>{{t "options.goBack"}}</a>
                        <input type='submit' class='w3-btn w3-cell w3-right yellow-black' style='width: 49%;' name='Email' id='btn' value='CONFERMA'>
                    </div>
                </form>
            </fieldset>
        </div>
    {{/if}}
{{else}}
    <div class='w3-content'>
        <div class='w3-container' style='width:400px; margin:auto;'>
            <div class='w3-panel'>
                <a href='/options/securityManagement' class='w3-btn w3-block w3-border-yellow w3-border'><i class='fas fa-user-cog'></i> {{t "options.subTitlePinManagement"}}</a>
            </div>
            {{#if pin}}
                <div class='w3-panel'>
                    <a href='/options/editPin' class='w3-btn w3-block w3-border-yellow w3-border'><i class='fas fa-pen'></i>{{t "options.subTitleEditPin"}}</a>
                </div>
                <div class='w3-panel'>
                    <a href='/options/resetPin' class='w3-btn w3-block w3-border-yellow w3-border'><i class='fas fa-eraser'></i> {{t "options.subTitleResetPin"}}</a>
                </div>
            {{/if}}

            <div class='w3-panel'>
                <a href='/options/editPwd' class='w3-btn w3-block w3-border-yellow w3-border'><i class='fas fa-unlock-alt'></i> {{t "options.subTitleEditPwd"}}</a>
            </div>
            <div class='w3-panel'>
                <a href='/options/editEmail' class='w3-btn w3-block w3-border-yellow w3-border'><i class='fas fa-envelope'></i> {{t "options.subTitleEditEmail"}}</a>
            </div>
            <div class='w3-panel'>
