<header>
    <div class='w3-bar w3-center black-yellow'>
        <a class='w3-bar-item w3-btn w3-mobile' href='/random'>{{t "menu.pwdGenerator"}}</a>
        <div class='w3-bar-item w3-mobile'>
            <i style='padding-left: 20px;'>{{t "index.subTitle"}}</i>
        </div>
        <div class='w3-right' style='display: table;'>
            <div class='w3-padding w3-mobile' style='float: left; position:relative;'>{{t "menu.currentUser"}}{{user}}</div>
            <a href='/options' class='w3-btn w3-mobile' style='height: 45px; float: left; position:relative;'>{{t "menu.options"}} <i class='fas fa-user-edit'></i></a>
            <a class='w3-bar-item w3-button w3-red w3-text-black w3-hover-black w3-hover-text-red w3-border w3-border-red w3-mobile' href='/login'>{{t "menu.logout"}} <i class='fas fa-sign-out-alt'></i></a>
        </div>
    </div>
</header>
<br>
{{!visualizzazione messaggio relativo alla buona o cattiva riuscita delle varie operazioni}}
{{#if msg}}
    <div id='msg' class='w3-modal-content w3-animate-zoom' style='width: 500px;'>
        {{#if msg.errore}}
            <div class='w3-container w3-red w3-text-black w3-center w3-xlarge'>
        {{else}}
            <div class='w3-container w3-green w3-text-black w3-center w3-xlarge'>
        {{/if}}

        <span onclick='document.getElementById("msg").style.display="none"' class='w3-button w3-display-topright'>&times;</span>

        {{#if msg.inserisci}}
            <p><i class='fas fa-check-circle'></i> {{t "index.addMsg"}}</p>
        {{else if msg.modifica}}
            <p><i class='fas fa-check-circle'></i> {{t "index.editMsg"}}</p>
        {{else if msg.elimina}}
            <p><i class='fas fa-check-circle'></i> {{t "index.deleteMsg"}}</p>
        {{else if msg.errore}}
            <i class='fas fa-exclamation-triangle'></i> {{t "error"}}
            <p>{{t "index.errorMsg"}}</p>
        {{/if}}
    </div>
    </div>
{{/if}}
<div class='w3-container' style='width: 350px; margin: auto;'>
    <fieldset class='w3-card w3-border-black'>
        <legend class='w3-large w3-center'><b>{{t "index.formTitle"}}</b></legend>
        <form action='/index' method='post' class='w3-container black-yellow'>
            <input type='hidden' name='_csrf' value='{{csfrToken}}'>
            <input type='hidden' name='id' id='id'>
            <div class='w3-panel'>
                <label><i class='fas fa-laptop-house'></i> {{t "index.siteLabel"}}</label>
                <input type='text' name='sito' id='sito' class='w3-input w3-border w3-border-black yellow-black' required autofocus />
            </div>
            <div class='w3-panel'>
                <label><i class='fas fa-user'></i> {{t "data.userLabel"}}</label>
                <input type='text' name='user' id='user' class='w3-input w3-border w3-border-black yellow-black' required autofocus />
            </div>
            <div class='w3-panel'>
                <label><i class='fas fa-key'></i> {{t "data.pwdLabel"}}</label>
                <div class='w3-cell-row yellow-black'>
                    <span class='w3-cell'><input type='password' name='pwd' id='pwd' class='w3-input w3-cell w3-border w3-border-black yellow-black' required /></span>
                    <span class='w3-cell'><i class='fas fa-eye icon' style='margin-left: 5px; margin-right: 5px;' id='icona' onclick="showhide(this, 'pwd');"></i></span>
                </div>
            </div>
            <div class='w3-panel w3-cell-row w3-center'>
                <input type='reset' class='w3-btn w3-cell w3-left yellow-black' style='width: 49%;' value='CANCELLA' onclick='annulla();'>
                <input type='submit' class='w3-btn w3-cell w3-right yellow-black' style='width: 49%;' name='Invia' id='btn' value='INSERISCI'>
            </div>
        </form>
    </fieldset>
</div>

<br>
<h1 class='w3-center w3-xxlarge yellow-black'><b>{{t "index.tableTitle"}}</b></h1>
<div class='w3-container' style='overflow-x:auto;'>
    {{#if dati}}
        <div class='w3-container'>
            <input type="text" class='w3-input yellow-black' id="searchbar" oninput="w3.filterHTML('#table', '.item', this.value)" placeholder="{{t "index.search"}}">
        </div>
        <br>
        <table id='table' class='w3-card w3-table w3-border w3-bordered w3-border-yellow w3-responsive' style='display: table;'>
            <tr class='w3-border-yellow' style='position: sticky;'>
                <th style='width:27%; min-width:300px;'>{{t "index.siteLabel"}}</th>
                <th style='width:27%; min-width:300px;'>{{t "data.userLabel"}}</th>
                <th style='width:27%; min-width:300px;'>{{t "data.pwdLabel"}}</th>
                <th style='width:19%; min-width:250px;'></th>
            </tr>
            {{#each dati}}
                <tr class='yellow-black w3-border-yellow w3-hover-border-black item'>
                    <td id='{{this.ID}}s' style='width:30%; min-width:300px; height:50px;'>{{this.SitoApp}}</td>
                    <td id='{{this.ID}}u' style='width:30%; min-width:300px; height:50px;'>{{this.Username}}</td>
                    <td style='width:30%; min-width:350px; height:50px;'>
                        <div class='w3-cell-row'>
                            <div class='w3-cell'><input type='password' id='{{this.ID}}p' style='min-width:300px; height: 30px;' class='w3-input w3-border w3-border-black yellow-black' value='{{this.Password}}' readonly /></div>
                            <div class='w3-cell'><i class='fas fa-eye icon w3-xlarge' style="margin-left:10px;" onclick="showhide(this,'{{this.ID}}p');"></i></div>
                            <div class='w3-cell'><i class='fas fa-copy icon w3-xlarge' style="margin-left:10px;" onclick="copia({{this.ID}});"></i></div>
                        </div>
                    </td>
                    <td class='w3-cell-row' style='width: 10%; min-width:250px; padding:5px; min-height:50px;'>
                        <form action='/index' method='post' style='margin:0px; padding:0px;'>
                            <input type='hidden' name='_csrf' value='{{csfrToken}}'>
                            <i class='fas fa-edit' onclick='modifica({{this.ID}});' title="MODIFICA"></i>
                            <button type='submit' name='Invia' value='ELIMINA' onclick="return confirmDelete();" title="ELIMINA"><i class='fas fa-trash-alt black-yellow'></i></button>
                            <input type='hidden' name='id' value='{{this.ID}}'>
                        </form>
                    </td>
                </tr>
            {{/each}}
        </table>
    {{else}}
        <div class='w3-center'>{{t "index.noData"}}</div>
    {{/if}}
</div>
<script src="https://www.w3schools.com/lib/w3.js"></script>
<script>
    function copia(id) {
        /* Get the text field */
        var pwd = document.getElementById(id + "p").value;
        navigator.clipboard.writeText(pwd)
            .then(() => {
                console.log("Password copiata!");
                alert("Password copiata!");
            })
            .catch(err => {
                console.error("Errore nella copia:", err);
            });
    }

    function modifica(i) {
        var s = document.getElementById(i + 's').innerHTML;
        var u = document.getElementById(i + 'u').innerHTML;
        var p = document.getElementById(i + 'p').value;
        document.getElementById('sito').value = s;
        document.getElementById('user').value = u;
        document.getElementById('pwd').value = p;
        document.getElementById('id').value = i;
        document.getElementById('btn').value = 'MODIFICA';
    }

    function annulla() {
        document.getElementById('sito').value = '';
        document.getElementById('user').value = '';
        document.getElementById('pwd').value = '';
        document.getElementById('id').value = '';
        document.getElementById('btn').value = 'INSERISCI';
    }

    window.onclick = function (event) {
        if (event.target == document.getElementById('msg')) {
            document.getElementById('msg').style.display = 'none';
        }
    }

    function showhide(icon, target) {
        var x = document.getElementById(target);
        if (x.type === 'password') {
            x.type = 'text';
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
        } else {
            x.type = 'password';
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
        }
    }

    function confirmDelete() {
        return confirm("Sei sicuro di voler eliminare questi dati?")
    }
</script>